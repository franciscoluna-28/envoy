    },
    "servers": [
        {
            "url": "//localhost:8080"
        }
    ],
    "components": {
        "securitySchemes": {
            "CookieAuth": {
                "description": "Authentication cookie containing JWT token",
                "type": "apiKey",
                "name": "session_token",
                "in": "cookie"
            }
        },
        "schemas": {
            "auth.LoginInput": {
                "type": "object",
                "required": [
                    "email",
                    "password"
                ],
                "properties": {
                    "email": {
                        "type": "string"
                    },
                    "password": {
                        "type": "string"
                    }
                }
            },
            "auth.RegisterInput": {
                "type": "object",
                "required": [
                    "email",
                    "password"
                ],
                "properties": {
                    "email": {
                        "type": "string"
                    },
                    "password": {
                        "type": "string",
                        "minLength": 8
                    }
                }
            },
            "auth.UserResponse": {
                "type": "object",
                "properties": {
                    "created_at": {
                        "type": "string"
                    },
                    "email": {
                        "type": "string"
                    },
                    "id": {
                        "type": "string"
                    }
                }
            },
            "environments.CertificatesConfig": {
                "type": "object",
                "properties": {
                    "ca_cert": {
                        "type": "string"
                    },
                    "client_cert": {
                        "type": "string"
                    },
                    "client_key": {
                        "type": "string"
                    }
                }
            },
            "environments.CreateEnvironmentRequest": {
                "type": "object",
                "required": [
                    "connection_url",
                    "name",
                    "project_id"
                ],
                "properties": {
                    "certificates": {
                        "$ref": "#/components/schemas/environments.CertificatesConfig"
                    },
                    "connection_url": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "project_id": {
                        "type": "string"
                    },
                    "ssl_mode": {
                        "type": "string",
                        "enum": [
                            "disable",
                            "allow",
                            "prefer",
                            "require",
                            "verify-ca",
                            "verify-full"
                        ]
                    }
                }
            },
            "environments.DatabaseConnection": {
                "type": "object",
                "required": [
                    "connection_string"
                ],
                "properties": {
                    "certificates_json": {
                        "type": "string"
                    },
                    "connection_string": {
                        "type": "string"
                    },
                    "ssl_mode": {
                        "type": "string"
                    }
                }
            },
            "projects.CreateProjectRequest": {
                "type": "object",
                "required": [
                    "name"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "maxLength": 255,
                        "minLength": 1
                    }
                }
            },
            "projects.ProjectDTO": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    }
                }
            },
            "projects.UpdateProjectRequest": {
                "type": "object",
                "required": [
                    "name"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "maxLength": 255,
                        "minLength": 1
                    }
                }
            },
            "shared.APIResponse": {
                "type": "object",
                "properties": {
                    "data": {},
                    "error": {
                        "$ref": "#/components/schemas/shared.ErrorCode"
                    },
                    "errors": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/shared.ValidationError"
                        }
                    },
                    "message": {
                        "type": "string"
                    },
                    "status": {
                        "type": "integer"
                    },
                    "success": {
                        "type": "boolean"
                    }
                }
            },
            "shared.ErrorCode": {
                "type": "string",
                "enum": [
                    "bad_request",
                    "invalid_input",
                    "unauthorized",
                    "internal_server_error",
                    "not_found",
                    "conflict"
                ],
                "x-enum-varnames": [
                    "ErrBadRequest",
                    "ErrInvalidInput",
                    "ErrUnauthorized",
                    "ErrInternalServer",
                    "ErrNotFound",
                    "ErrConflict"
                ]
            },
            "shared.ValidationError": {
                "type": "object",
                "properties": {
                    "field": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    }
                }
            }
        }
    }
}