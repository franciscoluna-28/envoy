        },
        "/api/v1/environments": {
            "post": {
                "security": [
                    {
                        "CookieAuth": []
                    }
                ],
                "description": "Creates a new database environment for a project",
                "tags": [
                    "Environments"
                ],
                "summary": "Create environment",
