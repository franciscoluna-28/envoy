                                    "$ref": "#/components/schemas/shared.APIResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/me": {
            "get": {
                "security": [
                    {
                        "CookieAuth": []
                    }
                ],
                "description": "Get the current authenticated user's profile",
                "tags": [
                    "User"
                ],
                "summary": "Get current user",
