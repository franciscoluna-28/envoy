                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/environments.CreateEnvironmentRequest"
                            }
                        }
                    },
                    "description": "Environment details",
                    "required": true
                },
                "responses": {
                    "201": {
                        "description": "Created",
                        "content": {
                            "application/json": {
